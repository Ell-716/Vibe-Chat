# Session (required for user authentication)
SESSION_SECRET=your_session_secret_here

# LLM Providers
# Default provider — required for basic chat functionality
GROQ_API_KEY=your_groq_api_key

# Optional providers — used for multi-model switching feature
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Zapier MCP Integration (Google Drive / Sheets via MCP Tools)
ZAPIER_MCP_API_KEY=your_zapier_mcp_api_key
ZAPIER_MCP_URL=your_zapier_mcp_url

# Discord Bot (Multi-Channel Support)
DISCORD_BOT_TOKEN=your_discord_bot_token

# Email Notifications (EmailJS)
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Database
DATABASE_URL=postgresql://user:password@host:port/database
